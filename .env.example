# Copy to .env.local for local dev, or set in Vercel / host dashboard.
# Must match your deployed backend origin (no trailing slash).

NEXT_PUBLIC_API_URL=https://backend-production-37a60.up.railway.app
# Socket.io client URL (usually same host as API, wss in production)
NEXT_PUBLIC_WS_URL=wss://backend-production-37a60.up.railway.app

# LiveKit WebSocket URL for browser (StudentDashboard, etc.)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-host

# Optional: Telegram deep links (register page)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_BOT_URL=

# Optional: Hugging Face token for summarize feature
NEXT_PUBLIC_HF_TOKEN=

# Server-only in Next API route (translate)
# LIBRETRANSLATE_URL=http://localhost:5000
